PROJECT_NAME=Sparkbot
ENVIRONMENT=local
HOST=127.0.0.1
PORT=8000

# Runtime provider selection: openai, openai_compatible, or ollama.
SPARKBOT_PROVIDER=openai
SPARKBOT_MODEL=
SPARKBOT_PROVIDER_TIMEOUT_SECONDS=45

# OpenAI. Keep this server-side only. Leave blank until copied into a local .env file.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible endpoints such as OpenRouter-style APIs, LM Studio, or llama.cpp server.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Ollama local model runtime.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
