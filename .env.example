PROJECT_NAME=Sparkbot
ENVIRONMENT=local
HOST=127.0.0.1
PORT=8000

# Local-only Ollama adapter. Disabled unless explicitly enabled.
SPARKBOT_LOCAL_MODELS_ENABLED=false
SPARKBOT_OLLAMA_BASE_URL=http://127.0.0.1:11434
SPARKBOT_OLLAMA_MODEL=

# Provider onboarding is environment-driven. Do not commit real values.
# Copy this file to .env for local use, then fill only the providers you intend to test.
SPARKBOT_PROVIDER_CALLS_ENABLED=false

# OpenRouter is the default cloud smoke path. Free :free models are enforced by default.
OPENROUTER_API_KEY=
SPARKBOT_OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
SPARKBOT_ALLOW_PAID_OPENROUTER_MODELS=false

# API-key provider slots. Leave keys blank for providers you do not intend to test.
OPENAI_API_KEY=
SPARKBOT_OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
SPARKBOT_ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_API_KEY=
SPARKBOT_GOOGLE_MODEL=gemini/gemini-2.0-flash
GROQ_API_KEY=
SPARKBOT_GROQ_MODEL=groq/llama-3.3-70b-versatile
MINIMAX_API_KEY=
SPARKBOT_MINIMAX_MODEL=minimax/MiniMax-M2.5
SPARKBOT_MINIMAX_CHAT_COMPLETIONS_URL=
XAI_API_KEY=
SPARKBOT_XAI_MODEL=xai/grok-4.20-multi-agent-0309

# Subscription providers are detected from local CLI sign-in state.
# Sparkbot never executes Codex or Claude CLIs directly; prompt dispatch requires the LIMA adapter URL below.
CODEX_HOME=
SPARKBOT_CODEX_AUTH_FILE=
SPARKBOT_CODEX_CLI=
SPARKBOT_CODEX_MODEL=openai-codex/gpt-5.3-codex
SPARKBOT_CODEX_SUBSCRIPTION_MODEL=
CLAUDE_HOME=
SPARKBOT_CLAUDE_AUTH_FILE=
SPARKBOT_CLAUDE_CLI=
SPARKBOT_CLAUDE_SUBSCRIPTION_ENABLED=false
SPARKBOT_CLAUDE_SUB_MODEL=claude-sub/sonnet
SPARKBOT_CLAUDE_SUBSCRIPTION_MODEL=
SPARKBOT_LIMA_PROVIDER_ADAPTER_URL=
